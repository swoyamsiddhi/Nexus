# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role key — NEVER expose this client-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="SRM Connect"
NEXT_PUBLIC_APP_DESCRIPTION="The campus platform for SRM University students"

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
# Supabase Redirect URL after OAuth / Magic Link (add in Supabase Auth settings)
# http://localhost:3000/auth/callback
