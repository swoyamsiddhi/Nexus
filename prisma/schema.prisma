// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  STUDENT
  CLUB_ADMIN
  SUPER_ADMIN
}

enum ClubCategory {
  TECH
  CULTURAL
  SPORTS
  ACADEMIC
  OTHER
}

enum EventType {
  COMPETITION
  WORKSHOP
  SEMINAR
  RECRUITMENT
  SOCIAL
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
}

enum TeamStatus {
  FORMING
  COMPLETE
  DISBANDED
}

enum TeamMemberRole {
  LEADER
  MEMBER
}

enum TeamMemberStatus {
  ACTIVE
  LEFT
  REMOVED
}

enum ConnectionRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  CLUB_INVITE
  EVENT_REMINDER
  EVENT_UPDATE
  REGISTRATION_CONFIRMED
  REGISTRATION_CANCELLED
  TEAM_INVITE
  TEAM_JOINED
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  ANNOUNCEMENT
  GENERAL
}

// ============================================================
// MODELS
// ============================================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String   // bcrypt hashed
  name        String
  avatar      String?
  bio         String?  @db.Text
  role        Role     @default(STUDENT)
  collegeId   String?
  department  String?
  yearOfStudy Int?
  skills      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // NextAuth adapter (optional, if using OAuth alongside credentials)
  emailVerified DateTime?

  // Club administration
  adminOfClubs Club[] @relation("ClubAdmin")

  // Club memberships
  memberships ClubMember[]

  // Events
  registrations Registration[]

  // Teams
  ledTeams    Team[]       @relation("TeamLeader")
  teamMembers TeamMember[]

  // Networking
  sentConnectionRequests     ConnectionRequest[] @relation("ConnectionSender")
  receivedConnectionRequests ConnectionRequest[] @relation("ConnectionReceiver")

  // Connections (accepted, bidirectional via self-relation)
  connections    User[] @relation("UserConnections")
  connectedWith  User[] @relation("UserConnections")

  // Notifications
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@index([collegeId, department])
  @@map("users")
}

model Club {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?      @db.Text
  logo        String?
  bannerImage String?
  category    ClubCategory @default(OTHER)
  socialLinks Json?        // { instagram, twitter, linkedin, website, discord }
  isVerified  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Admin
  adminId String
  admin   User   @relation("ClubAdmin", fields: [adminId], references: [id])

  // Members
  members ClubMember[]

  // Events
  events Event[]

  @@index([slug])
  @@index([category])
  @@index([adminId])
  @@map("clubs")
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String
  userId   String
  joinedAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
  @@map("club_members")
}

model Event {
  id                   String      @id @default(cuid())
  title                String
  slug                 String      @unique
  description          String?     @db.Text
  type                 EventType
  mode                 EventMode   @default(OFFLINE)
  status               EventStatus @default(DRAFT)
  startDate            DateTime
  endDate              DateTime?
  venue                String?
  maxParticipants      Int?
  registrationDeadline DateTime?
  posterImage          String?
  attachments          Json?       // [{ name, url, type }]
  isTeamEvent          Boolean     @default(false)
  minTeamSize          Int?
  maxTeamSize          Int?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Club
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  // Relations
  registrations Registration[]
  teams         Team[]

  @@index([clubId, status])
  @@index([startDate])
  @@index([type])
  @@index([status])
  @@map("events")
}

model Registration {
  id               String             @id @default(cuid())
  status           RegistrationStatus @default(PENDING)
  registrationData Json?              // Custom form field responses
  registeredAt     DateTime           @default(now())
  attendedAt       DateTime?

  // Relations
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Nullable — only filled for team events
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@index([userId])
  @@index([teamId])
  @@map("registrations")
}

model Team {
  id                String     @id @default(cuid())
  name              String
  description       String?    @db.Text
  isLookingForMembers Boolean  @default(true)
  requiredSkills    String[]
  status            TeamStatus @default(FORMING)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Event
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Leader
  leaderId String
  leader   User   @relation("TeamLeader", fields: [leaderId], references: [id])

  // Members
  members       TeamMember[]
  registrations Registration[]

  @@index([eventId, status])
  @@index([leaderId])
  @@map("teams")
}

model TeamMember {
  id       String           @id @default(cuid())
  role     TeamMemberRole   @default(MEMBER)
  status   TeamMemberStatus @default(ACTIVE)
  joinedAt DateTime         @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId, status])
  @@index([userId])
  @@map("team_members")
}

model ConnectionRequest {
  id          String                  @id @default(cuid())
  status      ConnectionRequestStatus @default(PENDING)
  message     String?                 @db.Text
  createdAt   DateTime                @default(now())
  respondedAt DateTime?

  senderId String
  sender   User   @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
  @@map("connection_requests")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?            // { eventId, clubId, teamId, ... } for deep linking
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}
