// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum Role {
  STUDENT
  FACULTY
  ORGANIZER
  ADMIN
}

enum OnboardingStatus {
  PENDING
  COMPLETE
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilityStatus {
  OPEN
  BUSY
  LOOKING_FOR_TEAM
}

enum MembershipRole {
  MEMBER
  OFFICER
  PRESIDENT
  LEAD
  CORE
}

enum MembershipStatus {
  PENDING
  ACTIVE
  ALUMNI
  REJECTED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventFormat {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventType {
  WORKSHOP
  HACKATHON
  CULTURAL
  TECH_TALK
  SEMINAR
  COMPETITION
  SOCIAL
  CUSTOM
}

enum RegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
  ATTENDED
}

enum ResearchType {
  SUMMER_INTERN
  SEMESTER_PROJECT
  THESIS
  RESEARCH_ASSISTANT
  READING_GROUP
  CUSTOM
}

enum CompensationType {
  PAID
  CREDIT
  VOLUNTEER
}

enum LocationType {
  ONSITE
  REMOTE
  HYBRID
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ProjectCategory {
  HACKATHON
  COURSE_PROJECT
  RESEARCH_PROJECT
  PERSONAL_STARTUP
  CREATIVE_DESIGN
  FREELANCE
}

enum ProjectPostType {
  NEED_HELP
  WANT_TO_JOIN
}

enum ConversationType {
  DIRECT
  GROUP
  EVENT
  TEAM
  CLUB
}

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  EVENT_REMINDER
  RESEARCH_MATCH
  APPLICATION_UPDATE
  TEAM_INVITE
  CLUB_ANNOUNCEMENT
  ADMIN_ALERT
  NEW_MESSAGE
}

// ===================================================
// NEXTAUTH ADAPTER MODELS
// ===================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================================================
// CORE USER MODELS
// ===================================================

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  password           String?
  role               Role               @default(STUDENT)
  onboardingStatus   OnboardingStatus   @default(PENDING)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lastActive         DateTime           @default(now())

  // Relations
  accounts          Account[]
  sessions          Session[]
  studentProfile    StudentProfile?
  facultyProfile    FacultyProfile?
  organizerProfile  OrganizerProfile?
  notifications     Notification[]
  sentMessages      Message[]
  participantIn     ConversationParticipant[]
  clubMemberships   ClubMembership[]
  eventRsvps        EventRegistration[]
  applications      Application[]
  projectPosts      ProjectPost[]
  projectInterests  ProjectInterest[]
  connections       Connection[]       @relation("ConnectionUser")
  connectedBy       Connection[]       @relation("ConnectionTarget")
  teamMembers       TeamMember[]
  sentConnections   Connection[]       @relation("ConnectionSent")
}

model StudentProfile {
  id               String             @id @default(cuid())
  userId           String             @unique
  rollNumber       String?
  branch           String?
  year             Int?
  cgpa             Float?
  isHosteler       Boolean            @default(false)
  bio              String?
  skills           String             @default("[]") // JSON array stored as string for SQLite
  interests        String             @default("[]") // JSON array
  availabilityStatus AvailabilityStatus @default(OPEN)
  linkedinUrl      String?
  githubUrl        String?
  portfolioUrl     String?
  resumeUrl        String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FacultyProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  designation     String?
  department      String?
  officeLocation  String?
  officeHours     String?
  bio             String?
  researchAreas   String   @default("[]") // JSON array
  publications    String   @default("[]") // JSON array
  labId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab  Lab? @relation(fields: [labId], references: [id])
  opportunities ResearchOpportunity[]
}

model OrganizerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  position  String?
  bio       String?
  since     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lab {
  id            String   @id @default(cuid())
  name          String
  description   String?
  researchAreas String   @default("[]")
  equipment     String?
  joiningProcess String?
  photos        String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  facultyProfiles FacultyProfile[]
  opportunities   ResearchOpportunity[]
}

// ===================================================
// CLUBS
// ===================================================

model Club {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  category      String?
  logo          String?
  banner        String?
  establishedYear Int?
  isActive      Boolean  @default(true)
  contactEmail  String?
  socialLinks   String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       ClubMembership[]
  events        Event[]
  coHostedEvents EventCoHost[]
  announcements ClubAnnouncement[]
}

model ClubMembership {
  id        String           @id @default(cuid())
  userId    String
  clubId    String
  role      MembershipRole   @default(MEMBER)
  status    MembershipStatus @default(PENDING)
  joinedAt  DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

model ClubAnnouncement {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

// ===================================================
// EVENTS
// ===================================================

model Event {
  id                  String      @id @default(cuid())
  title               String
  description         String?
  type                EventType   @default(CUSTOM)
  format              EventFormat @default(OFFLINE)
  status              EventStatus @default(DRAFT)
  clubId              String?
  organizerId         String
  startTime           DateTime
  endTime             DateTime?
  timezone            String      @default("Asia/Kolkata")
  venue               String?
  venueDetails        String?
  virtualLink         String?
  posterImage         String?
  bannerImage         String?
  capacity            Int?
  waitlistEnabled     Boolean     @default(false)
  requiresApproval    Boolean     @default(false)
  isPaid              Boolean     @default(false)
  amount              Float?
  teamFormationEnabled Boolean    @default(false)
  registrationFormJson String     @default("[]")
  tags                String      @default("[]")
  chatRoomId          String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  club          Club?              @relation(fields: [clubId], references: [id])
  coHosts       EventCoHost[]
  registrations EventRegistration[]
  teams         Team[]
}

model EventCoHost {
  eventId String
  clubId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  club  Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([eventId, clubId])
}

model EventRegistration {
  id        String             @id @default(cuid())
  eventId   String
  userId    String
  status    RegistrationStatus @default(REGISTERED)
  formAnswers String           @default("{}")
  teamId    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team?       @relation(fields: [teamId], references: [id])

  @@unique([eventId, userId])
}

model Team {
  id           String   @id @default(cuid())
  name         String
  eventId      String?
  projectIdea  String?
  techStack    String   @default("[]")
  lookingFor   String   @default("[]")
  status       String   @default("FORMING")
  leaderId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event         Event?              @relation(fields: [eventId], references: [id])
  members       TeamMember[]
  registrations EventRegistration[]
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  userId   String
  role     String?
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ===================================================
// RESEARCH
// ===================================================

model ResearchOpportunity {
  id                  String           @id @default(cuid())
  facultyId           String
  labId               String?
  title               String
  type                ResearchType     @default(CUSTOM)
  description         String?
  deliverables        String?
  duration            String?
  startDate           DateTime?
  endDate             DateTime?
  timeCommitmentHours Int?
  skillsRequired      String           @default("[]")
  yearPreference      String           @default("[]")
  branchPreference    String           @default("[]")
  minCgpa             Float?
  compensationType    CompensationType @default(VOLUNTEER)
  stipendAmount       Float?
  creditHours         Int?
  locationType        LocationType     @default(ONSITE)
  flexibleHours       Boolean          @default(false)
  applicationDeadline DateTime?
  positionsAvailable  Int              @default(1)
  status              String           @default("OPEN")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  faculty      FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  lab          Lab?           @relation(fields: [labId], references: [id])
  applications Application[]
}

model Application {
  id                  String            @id @default(cuid())
  opportunityId       String
  studentId           String
  resumeUrl           String?
  coverLetter         String?
  answersJson         String            @default("{}")
  portfolioLinks      String            @default("[]")
  status              ApplicationStatus @default(SUBMITTED)
  facultyNotes        String?
  interviewScheduledAt DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  opportunity ResearchOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  student     User                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, studentId])
}

// ===================================================
// TEAM FINDER / PROJECT POSTS
// ===================================================

model ProjectPost {
  id               String          @id @default(cuid())
  userId           String
  type             ProjectPostType @default(NEED_HELP)
  category         ProjectCategory @default(HACKATHON)
  title            String
  description      String?
  techStack        String          @default("[]")
  rolesNeeded      String          @default("[]")
  requiredSkills   String          @default("[]")
  compensationType String          @default("UNPAID")
  budgetAmount     Float?
  deadline         DateTime?
  courseCode       String?
  facultyAdvisor   String?
  status           String          @default("OPEN")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests   ProjectInterest[]
}

model ProjectInterest {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  post ProjectPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ===================================================
// MESSAGING
// ===================================================

model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType @default(DIRECT)
  name        String?
  contextType String?
  contextId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastRead       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  attachments    String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

// ===================================================
// CONNECTIONS
// ===================================================

model Connection {
  id         String   @id @default(cuid())
  userId     String
  targetId   String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  user   User @relation("ConnectionUser", fields: [userId], references: [id], onDelete: Cascade)
  target User @relation("ConnectionTarget", fields: [targetId], references: [id], onDelete: Cascade)
  sent   User @relation("ConnectionSent", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}

// ===================================================
// NOTIFICATIONS
// ===================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(ADMIN_ALERT)
  title     String
  message   String
  actionUrl String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
